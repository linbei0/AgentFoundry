Screen {
    layout: vertical;
}

#status-bar {
    height: 1;
    padding: 0 1;
    background: $surface;
}

#main {
    height: 1fr;
}

#conversation {
    width: 1fr;
    height: 1fr;
    padding: 1;
    border: solid $primary;
    overflow-y: auto;
}

#side-bar {
    width: 36;
    height: 1fr;
    padding: 1;
    border: solid $primary;
    overflow-y: auto;
}

#input-panel {
    height: 5;
    padding: 0 1;
}

#prompt-input {
    width: 1fr;
    height: 4;
}

#footer-bar {
    height: 1;
    padding: 0 1;
    background: $surface;
}

#resize-message {
    height: 1fr;
    content-align: center middle;
    padding: 1 2;
    border: solid $warning;
}

HelpModal,
ToolApprovalModal,
SessionOverlay,
SearchOverlay,
CommandSuggestionOverlay,
FileReferenceOverlay {
    align: center middle;
}

#help-dialog,
#approval-dialog,
#sessions-dialog,
#search-dialog,
#command-suggestions-dialog,
#file-ref-dialog {
    width: 72;
    height: auto;
    padding: 1 2;
    background: $surface;
}

#help-dialog,
#sessions-dialog,
#search-dialog,
#command-suggestions-dialog,
#file-ref-dialog {
    border: solid $primary;
}

#approval-dialog {
    border: solid $warning;
}

#help-title,
#approval-title {
    text-style: bold;
    margin-bottom: 1;
}

#help-body,
#approval-body {
    margin-bottom: 1;
}

#approval-buttons {
    align-horizontal: center;
    height: auto;
}

#approval-allow,
#approval-deny {
    margin: 0 2;
}

.hidden {
    display: none;
}
